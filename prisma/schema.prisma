generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// ENUMS
// ========================

enum EventStatus {
  active
  archived
  draft
}

enum TaskStatus {
  todo
  in_progress
  review
  done
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum ExpenseStatus {
  pending
  approved
  rejected
}

enum EventMemberRole {
  organizer
  team_lead
  member
  viewer
}

enum ActivityType {
  task_created
  task_completed
  task_updated
  expense_added
  expense_approved
  member_added
  channel_created
  event_updated
}

// ========================
// AUTH TABLES (better-auth)
// ========================

model user {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified Boolean   @default(false)
  image         String?
  password      String?
  phone         String?
  location      String?
  bio           String?
  role          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      account[]
  sessions      session[]
  events        event[]         @relation("OrganizerEvents")
  eventMembers  event_member[]
  tasks         task[]          @relation("AssigneeTasks")
  activities    activity[]
  messages      message[]
}

model account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ========================
// APP TABLES
// ========================

model event {
  id          String      @id @default(uuid())
  title       String
  description String?
  date        DateTime
  location    String?
  budget      Decimal?    @db.Decimal(10, 2)
  category    String?
  type        String?
  status      EventStatus @default(active)
  guestCount  Int?
  organizerId String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  organizer    user           @relation("OrganizerEvents", fields: [organizerId], references: [id], onDelete: Cascade)
  channels     channel[]
  tasks        task[]
  expenses     expense[]
  eventMembers event_member[]
  activities   activity[]
  messages     message[]
}

model channel {
  id          String   @id @default(uuid())
  eventId     String
  name        String
  description String?
  icon        String?
  color       String?
  createdAt   DateTime @default(now())

  event        event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subgroups    subgroup[]
  tasks        task[]
  expenses     expense[]
  eventMembers event_member[]
  messages     message[]
}

model subgroup {
  id        String   @id @default(uuid())
  channelId String
  name      String
  members   Int      @default(1)
  createdAt DateTime @default(now())

  channel channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model task {
  id          String       @id @default(uuid())
  eventId     String
  channelId   String?
  assigneeId  String?
  title       String
  description String?
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(medium)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  event    event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  channel  channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  assignee user?    @relation("AssigneeTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
}

model expense {
  id          String        @id @default(uuid())
  eventId     String
  channelId   String?
  amount      Decimal       @db.Decimal(10, 2)
  description String
  category    String?
  status      ExpenseStatus @default(pending)
  date        DateTime?
  createdAt   DateTime      @default(now())

  event   event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  channel channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
}

model event_member {
  id        String          @id @default(uuid())
  eventId   String
  userId    String
  role      EventMemberRole @default(member)
  channelId String?
  joinedAt  DateTime        @default(now())

  event   event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
}

model activity {
  id          String       @id @default(uuid())
  eventId     String
  userId      String?
  type        ActivityType
  description String?
  metadata    String?
  createdAt   DateTime     @default(now())

  event event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  user? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model message {
  id        String   @id @default(uuid())
  eventId   String
  channelId String?
  userId    String
  content   String
  createdAt DateTime @default(now())

  event   event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  channel channel? @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
